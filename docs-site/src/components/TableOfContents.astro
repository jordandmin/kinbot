---
/**
 * TableOfContents override — Aurora-styled right sidebar TOC.
 */
import Default from '@astrojs/starlight/components/TableOfContents.astro';
---

<div class="kb-toc-wrap">
	<Default><slot /></Default>
</div>

<style>
	.kb-toc-wrap {
		position: relative;
	}

	/* Heading "On this page" */
	:global(.kb-toc-wrap h2) {
		font-size: 0.75rem !important;
		font-weight: 700 !important;
		text-transform: uppercase !important;
		letter-spacing: 0.06em !important;
		background: linear-gradient(
			135deg,
			oklch(0.60 0.22 300 / 0.9),
			oklch(0.66 0.24 340 / 0.9)
		);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		margin-bottom: 0.75rem !important;
	}

	/* Links */
	:global(.kb-toc-wrap a) {
		position: relative;
		transition: color 0.15s ease, background 0.15s ease !important;
		border-radius: 0.375rem !important;
	}

	:global(.kb-toc-wrap a:hover) {
		color: var(--sl-color-accent-high) !important;
		background: oklch(0.60 0.22 300 / 0.05) !important;
	}

	/* Active indicator: gradient left bar */
	:global(.kb-toc-wrap a[aria-current='true']) {
		color: var(--sl-color-accent) !important;
		font-weight: 600 !important;
		background: oklch(0.60 0.22 300 / 0.08) !important;
	}

	:global(.kb-toc-wrap a[aria-current='true'])::before {
		content: '';
		position: absolute;
		inset-block: 4px;
		inset-inline-start: 0;
		width: 2px;
		border-radius: 2px;
		background: linear-gradient(
			180deg,
			oklch(0.60 0.22 300),
			oklch(0.66 0.24 340)
		);
	}

	/* Light mode */
	:root[data-theme='light'] :global(.kb-toc-wrap h2) {
		background: linear-gradient(
			135deg,
			oklch(0.42 0.24 300 / 0.9),
			oklch(0.48 0.26 340 / 0.9)
		);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}
</style>
