---
/**
 * Footer override — subtle copyright + back-to-site link.
 */
import Default from '@astrojs/starlight/components/Footer.astro';
---

<Default><slot /></Default>
<div class="kb-site-footer">
	<a href="/kinbot/" class="kb-back-link">
		<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
		Back to KinBot site
	</a>
	<span class="kb-copyright">© {new Date().getFullYear()} KinBot</span>
</div>

<style>
	.kb-site-footer {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1rem 0 2rem;
		font-size: 0.8125rem;
		color: var(--sl-color-gray-3);
		border-top: 1px solid oklch(0.60 0.22 300 / 0.06);
		margin-top: 1rem;
	}

	.kb-back-link {
		display: inline-flex;
		align-items: center;
		gap: 0.375rem;
		text-decoration: none;
		color: var(--sl-color-gray-3);
		transition: color 0.2s ease;
	}

	.kb-back-link:hover {
		color: var(--sl-color-accent);
	}

	.kb-copyright {
		opacity: 0.6;
	}
</style>
