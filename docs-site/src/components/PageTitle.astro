---
/**
 * PageTitle override — Aurora gradient on content page h1.
 */
---

<h1 id="_top" class="kb-page-title">{Astro.locals.starlightRoute.entry.data.title}</h1>

<style>
	.kb-page-title {
		margin-top: 1rem;
		font-size: var(--sl-text-h1);
		line-height: var(--sl-line-height-headings);
		font-weight: 700;
		background: linear-gradient(
			135deg,
			oklch(0.60 0.22 300) 0%,
			oklch(0.66 0.24 340) 50%,
			oklch(0.76 0.16 15) 100%
		);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	:root[data-theme='light'] .kb-page-title {
		background: linear-gradient(
			135deg,
			oklch(0.42 0.24 300) 0%,
			oklch(0.48 0.26 340) 50%,
			oklch(0.55 0.20 15) 100%
		);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}
</style>
